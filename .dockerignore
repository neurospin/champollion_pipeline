# Pixi-managed conda environment — rebuilt by `pixi install` inside Docker (20 GB)
.pixi/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.hypothesis/

# Git internals (not needed in the image)
.git/

# Editor / CI artefacts
.vscode/
*.env
.env
settings.json
*.prof

# GitHub Actions (Dockerfile is specified with -f, not needed in context)
.github/

# Sensitive data — notebooks may contain subject IDs in executed outputs;
# CSVs may contain participant lists. Excluded as a defence-in-depth measure.
**/*.ipynb
**/*.csv
